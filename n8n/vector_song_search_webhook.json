    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst rawBody = JSON.stringify({\n  statement: `\n    CALL db.index.vector.queryNodes('song_embedding_index', 5, $embedding)\n    YIELD node, score\n    MATCH (node)-[:BY_ARTIST]->(artist:Artist)\n    RETURN\n      node.title AS song,\n      artist.name AS artist,\n      node.summary AS summary,\n      node.url AS url,\n      score\n    ORDER BY score DESC\n  `.replace(/\\s+/g, \" \").trim(),\n  parameters: {\n    embedding: item.data?.[0]?.embedding || []\n  }\n});\n\nreturn [\n  {\n    json: {\n      rawBody\n    }\n  }\n];"
      },
