      "webhookId": "b1b5c865-26e9-4a0a-b3d2-96d2d86568f3"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst rawQuery =\n  typeof item.body?.query === \"string\" ? item.body.query :\n  typeof item.query === \"string\" ? item.query :\n  typeof item.song === \"string\" ? item.song :\n  typeof item.text === \"string\" ? item.text :\n  \"\";\n\nreturn [\n  {\n    json: {\n      query: rawQuery.trim()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        16,
        0
      ],
      "id": "0b602a9d-330b-4513-b4f4-6b53b8811bba",
      "name": "Prepare Query"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst fields = item.data?.fields || [];\nconst values = item.data?.values || [];\nconst originalQuery = $('Prepare Query').first().json.query || \"your query\";\n\nif (!values.length) {\n  return [\n    {\n      json: {\n        found: false,\n        response: `I could not find any similar songs for: ${originalQuery}`\n      }\n    }\n  ];\n}\n\nfunction shorten(text, max = 140) {\n  const clean = String(text || \"\").replace(/\\s+/g, \" \").trim();\n  if (clean.length <= max) return clean;\n  return clean.slice(0, max).trim() + \"...\";\n}\n\nconst matches = values.map(row => {\n  const mapped = {};\n  fields.forEach((field, index) => {\n    mapped[field] = row[index];\n  });\n\n  return {\n    song: mapped.song,\n    artist: mapped.artist,\n    summary: shorten(mapped.summary, 140),\n    url: mapped.url,\n    score: mapped.score\n  };\n});\n\nconst lines = [];\nlines.push(`Similar songs for: ${originalQuery}`);\nlines.push(\"\");\n\nfor (const match of matches) {\n  lines.push(`- ${match.song} — ${match.artist} (${Number(match.score).toFixed(3)})`);\n}\n\nreturn [\n  {\n    json: {\n      found: true,\n      response: lines.join(\"\\n\"),\n      matches\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
